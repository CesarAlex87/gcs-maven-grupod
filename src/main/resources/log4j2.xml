<?xml version="1.0" encoding="UTF-8"?>
<!-- Configuracion de Log4j2 para depcheck.
     Salida a consola (stderr) con patron legible; nivel INFO para la app. -->
<Configuration status="WARN">
  <Appenders>
    <Console name="Console" target="SYSTEM_ERR">
      <PatternLayout pattern="%d{HH:mm:ss.SSS} [%-5level] %logger{1} - %msg%n"/>
    </Console>
  </Appenders>
  <Loggers>
    <Logger name="ec.edu.ug.gcs.grupod.depcheck" level="info" additivity="false">
      <AppenderRef ref="Console"/>
    </Logger>
    <Root level="warn">
      <AppenderRef ref="Console"/>
    </Root>
  </Loggers>
</Configuration>
